# LLM Provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI settings (used when LLM_PROVIDER=openai AND/OR for Whisper speech-to-text
# AND/OR for parsing uploaded HLD diagram images — gpt-4o is vision-capable).
# Setting OPENAI_API_KEY enables Whisper STT and image-to-diagram automatically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional: override the model used for parsing diagram images (defaults to OPENAI_MODEL)
# OPENAI_VISION_MODEL=gpt-4o

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS origin for frontend dev server
CORS_ORIGIN=http://localhost:5173
